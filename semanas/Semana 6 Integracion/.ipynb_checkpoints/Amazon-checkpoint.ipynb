    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql.functions import col, desc\n",
    "\n",
    "# Iniciamos sesión asegurando la conexión a la BD correcta\n",
    "spark = SparkSession.builder \\\n",
    "    .appName(\"Analisis_Real_Amazon_Laptops\") \\\n",
    "    .config(\"spark.mongodb.read.connection.uri\", \"mongodb://database:27017/TiendaBigData.AmazonLaptops\") \\\n",
    "    .config(\"spark.jars.packages\", \"org.mongodb.spark:mongo-spark-connector_2.12:10.3.0\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "# Forzar lectura sin caché\n",
    "spark.catalog.clearCache()\n",
    "\n",
    "try:\n",
    "    df = spark.read.format(\"mongodb\").load()\n",
    "    \n",
    "    # Filtramos por si acaso quedaron nulos\n",
    "    df_laptops = df.filter(col(\"identificador\").isNotNull())\n",
    "\n",
    "    print(\"\\n--- VALIDACIÓN DE DATOS ACTUALES ---\")\n",
    "    # Si aquí ves \"HP\", \"Lenovo\" o \"Acer\", ¡lo logramos!\n",
    "    df_laptops.select(\"identificador\", \"valor\").show(10, truncate=False)\n",
    "\n",
    "    # Análisis de los más repetidos (marcas/modelos)\n",
    "    df_laptops.groupBy(\"identificador\").count().orderBy(desc(\"count\")).show(5)\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"Error al leer datos: {e}\")"
   ]
